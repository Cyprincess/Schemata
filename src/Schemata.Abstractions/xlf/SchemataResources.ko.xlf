<?xml version="1.0" encoding="utf-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.2"
  xsi:schemaLocation="urn:oasis:names:tc:xliff:document:1.2 xliff-core-1.2-transitional.xsd">
  <file datatype="xml" source-language="en" target-language="ko"
    original="../SchemataResources.resx">
    <body>
      <trans-unit id="DEPENDENCY_AUTO_REGISTERED">
        <source>{0} depends on {1}, it will be added automatically.</source>
        <target state="translated">{0}은(는) {1}에 종속되어 자동으로 추가됩니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="DEPENDENCY_REQUIRED">
        <source>{0} requires {1}, you should add it manually.</source>
        <target state="translated">{0}에는 {1}이(가) 필요합니다. 수동으로 추가해 주세요.</target>
        <note />
      </trans-unit>
      <trans-unit id="DEPENDENCY_SUGGESTED">
        <source>{0} suggests adding {1}.</source>
        <target state="translated">{0}에서 {1} 추가를 제안합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_ARGUMENT">
        <source>The request contains an invalid argument.</source>
        <target state="translated">요청에 잘못된 인수가 포함되어 있습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="TENANT_RESOLUTION_FAILED">
        <source>Unable to resolve tenant for the current request.</source>
        <target state="translated">현재 요청에 대한 테넌트를 확인할 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="FAILED_PRECONDITION">
        <source>The request cannot be executed in the current system state.</source>
        <target state="translated">현재 시스템 상태에서는 요청을 실행할 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="UNAUTHENTICATED">
        <source>The request does not have valid authentication credentials.</source>
        <target state="translated">요청에 유효한 인증 자격 증명이 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="PERMISSION_DENIED">
        <source>You do not have permission to perform this action.</source>
        <target state="translated">이 작업을 수행할 권한이 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="NOT_FOUND">
        <source>The requested resource was not found.</source>
        <target state="translated">요청한 리소스를 찾을 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="ALREADY_EXISTS">
        <source>The resource already exists.</source>
        <target state="translated">리소스가 이미 존재합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="CONCURRENCY_MISMATCH">
        <source>A concurrency conflict occurred while saving to the database.</source>
        <target state="translated">데이터베이스에 저장하는 동안 동시성 충돌이 발생했습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="VALIDATION_ERROR">
        <source>One or more validation errors occurred.</source>
        <target state="translated">하나 이상의 유효성 검사 오류가 발생했습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="RESOURCE_EXHAUSTED">
        <source>Rate limit exceeded.</source>
        <target state="translated">속도 제한을 초과했습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="NAMED_NOT_FOUND">
        <source>{0} '{1}' not found.</source>
        <target state="translated">{0} '{1}'을(를) 찾을 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="GENERIC_ERROR">
        <source>An error occurred.</source>
        <target state="translated">오류가 발생했습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="NOT_EMPTY">
        <source>'{0}' must not be empty.</source>
        <target state="translated">'{0}'은(는) 비어 있으면 안 됩니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="UNSUPPORTED_ALGORITHM">
        <source>Unsupported algorithm: {0}.</source>
        <target state="translated">지원되지 않는 알고리즘: {0}.</target>
        <note />
      </trans-unit>
      <trans-unit id="NOT_SUPPORTED">
        <source>'{0}' is not supported.</source>
        <target state="translated">'{0}'은(는) 지원되지 않습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="NOT_CONFIGURED">
        <source>'{0}' is not configured.</source>
        <target state="translated">'{0}'이(가) 구성되지 않았습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="SECTOR_IDENTIFIER_URI_REQUIRED">
        <source>Application has no sector identifier URI and no redirect URIs.</source>
        <target state="translated">애플리케이션에 섹터 식별자 URI 및 리디렉션 URI가 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="PATTERN_REQUIRED">
        <source>Cannot resolve a resource name without a pattern.</source>
        <target state="translated">패턴 없이는 리소스 이름을 확인할 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_TABLE_NAME">
        <source>Invalid table name '{0}' of type '{1}'.</source>
        <target state="translated">형식 '{1}'의 잘못된 테이블 이름 '{0}'.</target>
        <note />
      </trans-unit>
      <trans-unit id="TABLE_KEY_REQUIRED">
        <source>Entity must have at least one [TableKey].</source>
        <target state="translated">엔터티에는 [TableKey]가 하나 이상 있어야 합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="ENTITY_KEY_COUNT_MISMATCH">
        <source>Entity key count mismatch.</source>
        <target state="translated">엔터티 키 수가 일치하지 않습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="PARAMETER_NOT_RESOLVED">
        <source>Cannot resolve parameter '{0}' of type '{1}'.</source>
        <target state="translated">형식 '{1}'의 매개변수 '{0}'을(를) 확인할 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="METHOD_PARAMETER_NOT_RESOLVED">
        <source>Cannot resolve parameter '{0}' of method '{1}' on type '{2}'.</source>
        <target state="translated">형식 '{2}'의 메서드 '{1}'에 있는 매개변수 '{0}'을(를) 확인할 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="CONVERSION_FAILED">
        <source>Unable to convert '{0}' to {1}.</source>
        <target state="translated">'{0}'을(를) {1}(으)로 변환할 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="SOURCE_FIELD_REQUIRED">
        <source>Mapping for field {0} is missing a source field.</source>
        <target state="translated">필드 {0}의 매핑에 원본 필드가 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="TENANT_NOT_INITIALIZED">
        <source>Tenant is not initialized successfully.</source>
        <target state="translated">테넌트가 성공적으로 초기화되지 않았습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="ENTRY_ASSEMBLY_REQUIRED">
        <source>Entry assembly is null.</source>
        <target state="translated">항목 어셈블리가 null입니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="IMPLEMENTATION_REQUIRED">
        <source>The type {0} does not implement {1}.</source>
        <target state="translated">형식 {0}이(가) {1}을(를) 구현하지 않습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_PAYLOAD">
        <source>Invalid request payload.</source>
        <target state="translated">잘못된 요청 페이로드입니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_PARENT">
        <source>The parent is invalid.</source>
        <target state="translated">상위 리소스가 잘못되었습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="CROSS_PARENT_UNSUPPORTED">
        <source>Cross-parent reading is not supported for this resource.</source>
        <target state="translated">이 리소스에 대해 교차 상위 읽기가 지원되지 않습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_PAGE_TOKEN">
        <source>The page token is invalid or has expired.</source>
        <target state="translated">페이지 토큰이 잘못되었거나 만료되었습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_EXPRESSION">
        <source>The {0} expression is malformed.</source>
        <target state="translated">{0} 식의 형식이 잘못되었습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_FIELD">
        <source>Invalid field.</source>
        <target state="translated">잘못된 필드입니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_FIELD_NAME">
        <source>Invalid field name '{0}'.</source>
        <target state="translated">잘못된 필드 이름 '{0}'.</target>
        <note />
      </trans-unit>
      <trans-unit id="FUNCTION_NOT_REGISTERED">
        <source>Function '{0}' not registered.</source>
        <target state="translated">함수 '{0}'이(가) 등록되지 않았습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_PAGE_SIZE">
        <source>The page_size must not be negative.</source>
        <target state="new">The page_size must not be negative.</target>
        <note />
      </trans-unit>
      <trans-unit id="AUTHENTICATOR_KEY_REQUIRED">
        <source>The user manager must produce an authenticator key after reset.</source>
        <target state="translated">사용자 관리자는 재설정 후 인증기 키를 생성해야 합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_CLIENT_CREDENTIALS">
        <source>The client credentials are missing or invalid.</source>
        <target state="translated">클라이언트 자격 증명이 없거나 유효하지 않습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="CLIENT_SECRET_REQUIRED">
        <source>Client secret is required for confidential clients.</source>
        <target state="translated">기밀 클라이언트에는 클라이언트 비밀이 필요합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="MULTIPLE_CLIENT_AUTH_METHODS">
        <source>The request uses more than one client authentication method.</source>
        <target state="translated">요청이 둘 이상의 클라이언트 인증 방법을 사용합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_GRANT">
        <source>The provided grant is invalid, expired, or revoked.</source>
        <target state="translated">제공된 그랜트가 유효하지 않거나 만료되었거나 취소되었습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="PKCE_VERIFIER_MISMATCH">
        <source>The code_verifier does not match the code_challenge.</source>
        <target state="translated">code_verifier가 code_challenge와 일치하지 않습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_SCOPE">
        <source>The requested scope is not allowed for this client.</source>
        <target state="translated">요청된 범위가 이 클라이언트에 허용되지 않습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="UNAUTHORIZED_GRANT_TYPE">
        <source>The client is not authorized to use this grant type.</source>
        <target state="translated">클라이언트가 이 그랜트 유형을 사용할 권한이 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="ACCESS_DENIED">
        <source>The resource owner or authorization server denied the request.</source>
        <target state="translated">리소스 소유자 또는 인증 서버가 요청을 거부했습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_REDIRECT_URI">
        <source>The redirect_uri does not match any registered URI.</source>
        <target state="translated">redirect_uri가 등록된 URI와 일치하지 않습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="USER_CONSENT_REQUIRED">
        <source>User consent is required.</source>
        <target state="translated">사용자 동의가 필요합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="USER_AUTHENTICATION_REQUIRED">
        <source>User authentication is required.</source>
        <target state="translated">사용자 인증이 필요합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="AUTHORIZATION_PENDING">
        <source>The authorization request is still pending.</source>
        <target state="translated">인증 요청이 아직 보류 중입니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="SLOW_DOWN">
        <source>The polling interval is too short. Increase the interval and retry.</source>
        <target state="translated">폴링 간격이 너무 짧습니다. 간격을 늘리고 다시 시도하세요.</target>
        <note />
      </trans-unit>
      <trans-unit id="INTERNAL">
        <source>An internal server error occurred.</source>
        <target state="translated">내부 서버 오류가 발생했습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_PROMPT_COMBINATION">
        <source>The '{0}' prompt value cannot be combined with other values.</source>
        <target state="translated">프롬프트 값 '{0}'은(는) 다른 값과 결합할 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="UNSUPPORTED_PROMPT">
        <source>The '{0}' prompt value is not supported for this client.</source>
        <target state="translated">프롬프트 값 '{0}'은(는) 이 클라이언트에 지원되지 않습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="USER_IDENTITY_REQUIRED">
        <source>A valid user identity is required for this request.</source>
        <target state="translated">이 요청에는 유효한 사용자 ID가 필요합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="REQUIRED_SETTING_MISSING">
        <source>{0} is enabled but {1} is not set.</source>
        <target state="translated">{0}이(가) 활성화되었지만 {1}이(가) 설정되지 않았습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="ABSOLUTE_URI_REQUIRED">
        <source>{0} must be an absolute URI.</source>
        <target state="translated">{0}은(는) 절대 URI여야 합니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="MISSING_DEPENDENT_SETTING">
        <source>{0} is set but {1} is not set.</source>
        <target state="translated">{0}이(가) 설정되었지만 {1}이(가) 설정되지 않았습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="UNABLE_TO_RESOLVE">
        <source>Unable to resolve {0}.</source>
        <target state="translated">{0}을(를) 확인할 수 없습니다.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_FILTER">
        <source>The filter expression is invalid.</source>
        <target state="new">The filter expression is invalid.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_UPDATE_MASK">
        <source>The update_mask expression is invalid.</source>
        <target state="new">The update_mask expression is invalid.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_READ_MASK">
        <source>The read_mask expression is invalid.</source>
        <target state="new">The read_mask expression is invalid.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_NAME">
        <source>The resource name is invalid.</source>
        <target state="new">The resource name is invalid.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_ORDER_BY">
        <source>The order_by expression is invalid.</source>
        <target state="new">The order_by expression is invalid.</target>
        <note />
      </trans-unit>
      <trans-unit id="INVALID_REFERENCE">
        <source>The supplied reference does not resolve to any registered resource type.</source>
        <target state="new">The supplied reference does not resolve to any registered resource type.</target>
        <note />
      </trans-unit>
    </body>
  </file>
</xliff>
